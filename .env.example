# See SECURITY.md for full env checklist, backup/restore, and least-privilege guidance.
#
# Contact form (Formspree — free tier, no credit card, works on Vercel)
# 1. Create a form at https://formspree.io → get your form ID (e.g. xyzabc)
# 2. Set FORMSPREE_FORM_ID to that ID (e.g. FORMSPREE_FORM_ID=xyzabc)
# Formspree emails submissions to the address you set in the form settings.
FORMSPREE_FORM_ID=your_form_id

# Supabase (https://supabase.com/dashboard)
# Project URL and anon key: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Supabase Postgres (Prisma + app).
#
# MUST be a full connection URI starting with postgresql:// or postgres:// (Prisma rejects
# anything else). In Vercel, paste the value with NO surrounding quotes.
#
# Local dev: Session pooler (port 5432) is usually fine.
#
# Vercel / serverless: use Transaction pooler (port 6543), not Session (5432).
# Session mode caps concurrent clients and causes "MaxClientsInSessionMode" under load.
# Dashboard → Database → Connection string → Transaction pooler.
# Append: ?pgbouncer=true&connection_limit=1
# Example:
# postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL=

# UMS Hub app user (must match a Supabase Auth user email)
# Seed creates an app User with this email and role; create the same email in Supabase Auth (Dashboard → Authentication → Users).
HUB_BOOTSTRAP_EMAIL=admin@ultimatemarketingsmash.com
HUB_BOOTSTRAP_ROLE=ADMIN

# Optional: include deterministic demo records during seed.
SEED_SAMPLE_DATA=false

# Meta Marketing API & Facebook Login (Hub → Ads, Social).
# META_APP_ID: Facebook App ID from developers.facebook.com.
# META_APP_SECRET: Facebook App secret (server-side only, never exposed).
# META_BUSINESS_ID: Optional; used in Ads setup copy.
META_APP_ID=
META_APP_SECRET=
META_BUSINESS_ID=

# Social worker: secret for cron endpoint (set in Vercel → Settings → Environment Variables).
# Call GET/POST /api/cron/social-publish with header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Invoice email delivery (Hub → Mark as Sent). Resend.com API key.
# Set to enable automatic invoice emails when marking an invoice as Sent.
RESEND_API_KEY=

# Optional: from address for invoice emails. Defaults to company support email or HUB_BOOTSTRAP_EMAIL.
# Must be a verified domain in Resend for production.
# EMAIL_FROM=billing@yourdomain.com

# Portal & payments
# Base URL for portal links in emails. Defaults to VERCEL_URL in production.
# NEXT_PUBLIC_APP_URL=https://yoursite.com

# PayFast (South Africa) for client portal online payments.
# PAYFAST_MERCHANT_ID=
# PAYFAST_MERCHANT_KEY=
# PAYFAST_PASSPHRASE=
# PAYFAST_MODE=sandbox
